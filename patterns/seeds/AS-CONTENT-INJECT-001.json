      "MCP_TOOL_HANDLER",
      "LogOutput",
      "ExternalInput"
    ],
    "relation_types": [
      "FLOWS_INTO",
      "RETURNS"
    ],
    "min_entities": 3
  },
  "dataflow_signature": {
