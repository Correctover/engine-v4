        "sanitized": false,
        "content_type_checked": false
      }
    },
    "taint_mode": "transformed"
  },
  "constraints": {
    "required_properties": [
      "raw_content_passthrough"
    ],
    "absence_of": [
      "content_sanitization",
      "html_escape",
      "prompt_injection_filter",
      "content_type_validation"
    ],
    "attacker_capabilities": [
      "crafted_tool_output"
    ]
  },
  "remediation": "Sanitize MCP server response content: 1) Validate content types 2) HTML-escape text 3) Filter prompt injection patterns 4) Limit content size 5) Mark with untrusted boundary indicators.",
  "references": [
    "https://github.com/agentscope-ai/agentscope/pull/2131",
